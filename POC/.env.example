# ============================================================
# Enterprise Logistics Platform - Environment Configuration
# Copy to `.env` and adjust for your environment.
# ============================================================

# ---- Application ----
NODE_ENV=development
APP_NAME=Enterprise Logistics Platform
APP_PORT=3000
APP_GLOBAL_PREFIX=api
APP_DEFAULT_API_VERSION=1

# ---- MongoDB ----
# When running via docker-compose use host `mongo`; locally use `localhost`.
MONGO_URI=mongodb://mongo:27017/logistics
MONGO_DB_NAME=logistics

# ---- Redis (cache + BullMQ) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_SECONDS=60

# ---- JWT ----
JWT_ACCESS_SECRET=super-secret-access-key-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me
JWT_REFRESH_EXPIRES_IN=7d

# ---- Sessions / Cookies / CSRF ----
SESSION_SECRET=super-secret-session-key-change-me
CSRF_SECRET=super-secret-csrf-key-change-me
COOKIE_SECRET=super-secret-cookie-key-change-me

# ---- Security ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# ---- External APIs (HTTP module) ----
GOOGLE_MAPS_API_KEY=
CARRIER_API_BASE_URL=https://example-carrier.test/api
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1
HTTP_TIMEOUT_MS=8000
HTTP_MAX_RETRIES=3

# ---- Microservices (TCP transport) ----
USER_SERVICE_HOST=localhost
USER_SERVICE_PORT=3001
SHIPMENT_SERVICE_HOST=localhost
SHIPMENT_SERVICE_PORT=3002
NOTIFICATION_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_PORT=3003

# ---- File uploads ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
