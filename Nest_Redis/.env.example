# Server
PORT=3000
BASE_URL=http://localhost:3000

# URL storage TTL (seconds) — how long a short code lives before expiring
URL_TTL_SECONDS=3600

# Rate limiting for POST /shorten (per IP)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=60

# Redis connection.
# Leave commented to use the in-memory ioredis-mock (zero setup, resets on restart).
# Uncomment and point at a real Redis to switch with no code changes:
# REDIS_URL=redis://localhost:6379
